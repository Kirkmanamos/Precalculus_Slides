---
import type { Unit, Resource as ResourceT } from '../data/types';
import type { Course } from '../data/courses';
import Resource from './Resource.astro';

interface Props {
  unit: Unit;
  course: Course;
  open?: boolean;
}
const { unit, course, open = false } = Astro.props;
const n = unit.number;

// Unit-wide notes PDF, chosen by the course's variant.
const variantLabel = course.notesVariant === 'honors' ? 'Honors' : 'Regular';
const notes: ResourceT = {
  type: 'notes',
  title: `Unit ${n} Notes — ${variantLabel} (PDF)`,
  href: `notes/unit-${n}-notes-${course.notesVariant}.pdf`,
};
---

<details
  id={`unit-${n}`}
  open={open}
  data-unit={n}
  class="unit group scroll-mt-20 overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm [&_summary::-webkit-details-marker]:hidden"
>
  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 bg-slate-900 px-6 py-5 text-white">
    <div class="min-w-0">
      <p class="text-xs font-semibold tracking-wider text-indigo-300 uppercase">Unit {n}</p>
      <h2 class="mt-1 text-xl font-bold sm:text-2xl">{unit.title}</h2>
      {unit.blurb && <p class="mt-1 text-sm text-slate-300">{unit.blurb}</p>}
    </div>
    <div class="flex shrink-0 items-center gap-4">
      <div class="hidden text-right sm:block">
        <span class="text-lg font-bold" data-unit-pct>0%</span>
        <span class="block text-[11px] tracking-wide text-slate-400 uppercase">complete</span>
      </div>
      <svg
        class="h-6 w-6 transition-transform duration-200 group-open:rotate-180"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
      </svg>
    </div>
  </summary>

  <!-- Per-unit progress bar -->
  <div class="flex items-center gap-3 bg-slate-800 px-6 py-2 text-white">
    <div class="h-1.5 flex-1 overflow-hidden rounded-full bg-slate-700">
      <div class="h-full w-0 rounded-full bg-emerald-500 transition-all" data-unit-bar></div>
    </div>
    <button
      type="button"
      data-reset-unit={n}
      class="text-[11px] font-medium text-slate-400 uppercase transition hover:text-white"
    >
      Reset
    </button>
  </div>

  <!-- Unit notes -->
  <section class="border-b-4 border-indigo-100 bg-indigo-50/40">
    <header class="px-6 pt-3 pb-1">
      <h3 class="text-sm font-bold tracking-wide text-indigo-600 uppercase">Unit Resources</h3>
    </header>
    <Resource resource={notes} rid={`${n}|notes`} progress />
  </section>

  <div class="divide-y divide-slate-100">
    {
      unit.topics.map((topic) => (
        <section>
          <header class="bg-slate-50 px-6 py-3">
            <h3 class="flex items-center gap-2 text-sm font-bold tracking-wide text-slate-600 uppercase">
              <span class="text-indigo-500" aria-hidden="true">
                ●
              </span>
              Topic {topic.number} — {topic.title}
            </h3>
          </header>
          <div>
            {topic.resources.map((resource, i) => (
              <Resource resource={resource} rid={`${n}|${topic.number}|${i}`} progress />
            ))}
          </div>
        </section>
      ))
    }
  </div>
</details>
