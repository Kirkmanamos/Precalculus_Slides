---
import type { Unit } from '../data/types';
import Resource from './Resource.astro';

interface Props {
  unit: Unit;
  open?: boolean;
}
const { unit, open = false } = Astro.props;
---

<details
  open={open}
  class="group overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm [&_summary::-webkit-details-marker]:hidden"
>
  <summary
    class="flex cursor-pointer list-none items-center justify-between gap-4 bg-slate-900 px-6 py-5 text-white"
  >
    <div>
      <p class="text-xs font-semibold tracking-wider text-indigo-300 uppercase">
        Unit {unit.number}
      </p>
      <h2 class="mt-1 text-2xl font-bold">{unit.title}</h2>
      {unit.blurb && <p class="mt-1 text-sm text-slate-300">{unit.blurb}</p>}
    </div>
    <svg
      class="h-6 w-6 shrink-0 transition-transform duration-200 group-open:rotate-180"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
    </svg>
  </summary>

  <div class="divide-y divide-slate-100">
    {
      unit.topics.map((topic) => (
        <section>
          <header class="bg-slate-50 px-6 py-3">
            <h3 class="flex items-center gap-2 text-sm font-bold tracking-wide text-slate-600 uppercase">
              <span class="text-indigo-500" aria-hidden="true">
                ●
              </span>
              Topic {topic.number} — {topic.title}
            </h3>
          </header>
          <div>
            {topic.resources.map((resource) => (
              <Resource resource={resource} />
            ))}
          </div>
        </section>
      ))
    }
  </div>
</details>
