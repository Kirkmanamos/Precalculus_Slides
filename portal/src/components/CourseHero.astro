---
import type { Course } from '../data/courses';

interface Props {
  course: Course;
}
const { course } = Astro.props;
const embed = course.youtubeId ? `https://www.youtube.com/embed/${course.youtubeId}` : '';
---

<section class="grid items-center gap-8 py-10 md:grid-cols-2">
  <div>
    <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl">{course.name}</h1>
    <p class="mt-4 text-slate-600">{course.description}</p>
    <div class="mt-6 inline-flex items-center gap-2 rounded-lg bg-indigo-50 px-4 py-2 text-sm text-indigo-700">
      <span class="font-semibold">Tip:</span>
      Each unit has slides, notes, and practice. Work through them in order.
    </div>
  </div>

  <div>
    {
      embed ? (
        <div class="overflow-hidden rounded-xl border border-slate-200 shadow-sm">
          <iframe
            class="aspect-video w-full"
            src={embed}
            title={`${course.name} intro video`}
            loading="lazy"
            allowfullscreen
          />
        </div>
      ) : (
        <div class="flex aspect-video w-full flex-col items-center justify-center rounded-xl border-2 border-dashed border-slate-300 bg-white text-center text-slate-400">
          <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 0 1 0 .656l-5.603 3.113a.375.375 0 0 1-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112Z" />
            <circle cx="12" cy="12" r="9" />
          </svg>
          <p class="mt-2 text-sm font-medium">Intro video coming soon</p>
          <p class="text-xs">Add a YouTube ID in courses.ts</p>
        </div>
      )
    }
  </div>
</section>
