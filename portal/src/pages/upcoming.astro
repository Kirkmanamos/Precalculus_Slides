---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, isExternal } from '../lib/url';
import assignments from '../data/assignments.json';

interface Assignment {
  due: string;
  title: string;
  unit?: string;
  note?: string;
  href?: string;
}

const today = new Date();
today.setHours(0, 0, 0, 0);

// Show only future / current items, soonest first.
const upcoming = (assignments as Assignment[])
  .filter((a) => new Date(a.due) >= today)
  .sort((a, b) => +new Date(a.due) - +new Date(b.due));

const fmt = (iso: string) =>
  new Date(iso + 'T00:00:00').toLocaleDateString('en-US', {
    weekday: 'short',
    month: 'short',
    day: 'numeric',
  });
---

<BaseLayout title="Upcoming Assignments">
  <h1 class="text-3xl font-bold text-slate-900">Upcoming Assignments</h1>
  <p class="mt-2 text-slate-600">What's due next, soonest first.</p>

  {
    upcoming.length === 0 ? (
      <p class="mt-8 rounded-xl border border-slate-200 bg-white px-6 py-8 text-center text-slate-500">
        Nothing scheduled right now — check back soon!
      </p>
    ) : (
      <ul class="mt-6 space-y-3">
        {upcoming.map((a) => {
          const link = a.href ? (isExternal(a.href) ? a.href : site(a.href)) : null;
          return (
            <li class="flex items-start gap-4 rounded-xl border border-slate-200 bg-white px-5 py-4 shadow-sm">
              <div class="flex w-16 shrink-0 flex-col items-center rounded-lg bg-indigo-50 px-2 py-2 text-center">
                <span class="text-[11px] font-semibold tracking-wide text-indigo-500 uppercase">
                  {fmt(a.due).split(',')[0]}
                </span>
                <span class="text-sm font-bold text-indigo-700">{fmt(a.due).split(', ')[1]}</span>
              </div>
              <div class="min-w-0">
                {a.unit && <p class="text-xs font-semibold tracking-wide text-slate-400 uppercase">{a.unit}</p>}
                <h2 class="font-semibold text-slate-800">
                  {link ? (
                    <a href={link} target="_blank" rel="noopener" class="hover:text-indigo-600 hover:underline">
                      {a.title}
                    </a>
                  ) : (
                    a.title
                  )}
                </h2>
                {a.note && <p class="mt-1 text-sm text-slate-600">{a.note}</p>}
              </div>
            </li>
          );
        })}
      </ul>
    )
  }
</BaseLayout>
