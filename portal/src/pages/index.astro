---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../lib/url';
import { courses } from '../data/courses';
import unitsData from '../data/units.json';
import type { Unit } from '../data/types';

const unitCount = (unitsData as Unit[]).length;
---

<BaseLayout title="Kirk Amos's Math">
  <!-- Hero -->
  <section class="mb-10 overflow-hidden rounded-2xl bg-gradient-to-r from-indigo-600 to-violet-600 px-8 py-12 text-white shadow-lg">
    <h1 class="text-3xl font-bold sm:text-4xl">Kirk Amos's Math</h1>
    <p class="mt-3 max-w-2xl text-indigo-100">
      Course materials for my classes — interactive slides, notes, worksheets,
      and video tutorials, organized by unit and topic. Pick your class to get started.
    </p>
  </section>

  <!-- Class cards -->
  <section>
    <h2 class="text-sm font-bold tracking-wider text-slate-400 uppercase">My Classes</h2>
    <div class="mt-4 grid gap-5 sm:grid-cols-2">
      {
        courses.map((c) => (
          <a
            href={site(`${c.id}/`)}
            class="group flex flex-col justify-between rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:shadow-md"
          >
            <div>
              <h3 class="text-xl font-bold text-slate-900">{c.name}</h3>
              <p class="mt-2 text-sm text-slate-600">{c.tagline}</p>
            </div>
            <div class="mt-6 flex items-center justify-between">
              <span class="text-xs font-medium text-slate-400">{unitCount} units</span>
              <span class="text-sm font-semibold text-indigo-600 group-hover:underline">
                Open class →
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Quick links -->
  <section class="mt-10">
    <h2 class="text-sm font-bold tracking-wider text-slate-400 uppercase">Quick Links</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <a href={site('playgrounds/')} class="rounded-xl border border-slate-200 bg-white px-5 py-4 shadow-sm transition hover:border-indigo-300 hover:shadow">
        <h3 class="font-semibold text-indigo-600">Playgrounds →</h3>
        <p class="mt-1 text-sm text-slate-600">Interactive concept explorers.</p>
      </a>
      <a href={site('games/')} class="rounded-xl border border-slate-200 bg-white px-5 py-4 shadow-sm transition hover:border-indigo-300 hover:shadow">
        <h3 class="font-semibold text-indigo-600">Review Games →</h3>
        <p class="mt-1 text-sm text-slate-600">Jeopardy, Trashketball, and more.</p>
      </a>
      <a href={site('resources/')} class="rounded-xl border border-slate-200 bg-white px-5 py-4 shadow-sm transition hover:border-indigo-300 hover:shadow">
        <h3 class="font-semibold text-indigo-600">Helpful Resources →</h3>
        <p class="mt-1 text-sm text-slate-600">Tools, references, and formulas.</p>
      </a>
    </div>
  </section>
</BaseLayout>
